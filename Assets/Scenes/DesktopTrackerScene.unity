  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "<align=\"center\"><B>About</b></align>\n\nDeveloped by <link=\"https://www.philipturnbull.com/\"><u>Associate
    Professor Philip Turnbull</u></link> at the School of Optometry and Vision Science,
    <link=\"https://www.auckland.ac.nz/\"><u>University of Auckland</u></link>, Aotearoa
    New Zealand.\n\nIt is designed to enable conversations about the impact of eye
    disease on everyday tasks. This tool is not intended as a realistic disease simulation.
    \n\n\nBest experienced with a Tobii eyetracker (e.g.,4C or 5), but falls back
    to mouse mode when one is not available.\n\n\nAvailable from <link=\"https://github.com/fillupt/UnityTobiiLowVisionDefectDemo\"><u>Github</u></link>
    licensed under GPL-3.0. Please feel free to make suggestions at p.turnbull@auckland.ac.nz.\n\nThe
    video also depicts the <link=\"https://virtualpatient.co.nz\"><u>Virtual Patient</u></link>,
    a tool to learn optometry skills. \n\n\n"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 80bdf9d98dc051b498cdd0feceef5985, type: 2}
